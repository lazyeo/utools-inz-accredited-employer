{
  "main": "index.html",
  "preload": "preload/services.js",
  "logo": "logo.jpg",
  "development": {
    "main": "http://localhost:5173"
  },
  "features": [
    {
      "code": "inz-search",
      "explain": "新西兰移民局 (INZ) 认证雇主查询",
      "cmds": [
        "认证雇主",
        "查认证雇主",
        "AEWV",
        "Accredited Employer"
      ]
    },
    {
      "code": "inz-search-over",
      "explain": "查询复制/选中的公司名或 NZBN 是否为认证雇主",
      "mainPush": true,
      "cmds": [
        {
          "type": "regex",
          "label": "查询认证雇主",
          "match": "/^\\d{13}$/",
          "minLength": 13,
          "maxLength": 13
        },
        {
          "type": "regex",
          "label": "查询认证雇主",
          "match": "/^[A-Za-z0-9&'().,\/-][A-Za-z0-9&'().,\/-\\s]{2,120}$/",
          "minLength": 3,
          "maxLength": 120
        },
        {
          "type": "over",
          "label": "查询认证雇主",
          "minLength": 3,
          "maxLength": 120,
          "exclude": "/\\n/"
        }
      ]
    }
  ]
}
